---
import BaseLayout from '../layouts/BaseLayout.astro'
import {site} from '../config/site'
---

<BaseLayout
  title={`Stránka nenalezena – ${site.name}`}
  description="Požadovaná stránka nebyla nalezena."
  path="/404/"
  noindex={true}
>
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="max-w-xl rounded-3xl bg-white p-10 shadow-sm ring-1 ring-black/5">
      <h1 class="text-3xl font-semibold tracking-tight text-[#121212]">404</h1>
      <p class="mt-3 text-sm text-black/70">
        Tuhle stránku jsme nenašli. Zkuste se vrátit na úvod nebo do nabídky.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/" class="rounded-2xl bg-[#c58a2a] px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#b77d1f]">Úvod</a>
        <a href="/#napojovy-listek" class="rounded-2xl bg-white px-6 py-3 text-sm font-semibold text-black/80 shadow-sm ring-1 ring-black/10 hover:bg-black/5">Nabídka</a>
      </div>
    </div>
  </section>
</BaseLayout>

