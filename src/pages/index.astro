  <script is:inline>
    const chips = document.querySelectorAll('.menu-chip');
    const sections = document.querySelectorAll('.menu-section');
    const searchInput = document.getElementById('menu-search');
    const prevBtn = document.getElementById('menu-prev');
    const nextBtn = document.getElementById('menu-next');
    const pageInfo = document.getElementById('menu-page-info');
    let activeFilter = 'all';
    let activeQuery = '';
    let currentPage = 1;
    let maxPage = 1;
    const pageSize = 4;

    sections.forEach((section) => {
      section.addEventListener('toggle', () => {
        if (!section.open) return;
        sections.forEach((other) => {
          if (other !== section) other.removeAttribute('open');
        });
      });
    });

    const applyMenuFilter = () => {
      const visibleSections = [];
      sections.forEach((section) => {
        const sectionCategory = section.dataset.category;
        const sectionMatchesFilter = activeFilter === 'all' || sectionCategory === activeFilter;
        const rows = section.querySelectorAll('.menu-item');
        let visibleRows = 0;

        rows.forEach((row) => {
          const hay = (row.dataset.search || '').toLowerCase();
          const matchesQuery = !activeQuery || hay.includes(activeQuery);
          const visible = sectionMatchesFilter && matchesQuery;
          row.style.display = visible ? '' : 'none';
          if (visible) visibleRows += 1;
        });

        const sectionVisible = sectionMatchesFilter && visibleRows > 0;
        if (sectionVisible) visibleSections.push(section);
        section.style.display = 'none';
        section.removeAttribute('open');
      });

      maxPage = Math.max(1, Math.ceil(visibleSections.length / pageSize));
      if (currentPage > maxPage) currentPage = maxPage;
      if (currentPage < 1) currentPage = 1;

      const start = (currentPage - 1) * pageSize;
      const end = start + pageSize;
      visibleSections.slice(start, end).forEach((section) => {
        section.style.display = '';
      });

      if (pageInfo) pageInfo.textContent = `Strana ${currentPage} z ${maxPage}`;
      if (prevBtn) prevBtn.disabled = currentPage <= 1;
      if (nextBtn) nextBtn.disabled = currentPage >= maxPage;
      if (prevBtn) prevBtn.style.opacity = currentPage <= 1 ? '0.45' : '1';
      if (nextBtn) nextBtn.style.opacity = currentPage >= maxPage ? '0.45' : '1';
    };

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const filter = chip.dataset.filter || 'all';
        activeFilter = filter;
        currentPage = 1;
        chips.forEach((c) => {
          c.classList.remove('is-active', 'bg-white', 'text-black');
          c.classList.add('bg-white/10', 'text-white');
        });
        chip.classList.add('is-active', 'bg-white', 'text-black');
        chip.classList.remove('bg-white/10', 'text-white');
        applyMenuFilter();
      });
    });

    if (searchInput) {
      searchInput.addEventListener('input', (event) => {
        activeQuery = event.target.value.trim().toLowerCase();
        currentPage = 1;
        applyMenuFilter();
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        currentPage -= 1;
        applyMenuFilter();
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        currentPage += 1;
        applyMenuFilter();
      });
    }

    applyMenuFilter();

    const reveals = document.querySelectorAll('.reveal');
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      },
      {threshold: 0.12}
    );
    reveals.forEach((el) => revealObserver.observe(el));

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const beans = document.querySelectorAll('.bean-interactive');

    beans.forEach((bean, index) => {
      bean.style.setProperty('--phase', `${index * 0.85}`);
    });

    if (!reduceMotion) {
      const animateBeans = (time) => {
        beans.forEach((bean) => {
          const phase = Number(bean.style.getPropertyValue('--phase') || 0);
          const lift = Math.sin(time / 850 + phase) * 4;
          bean.style.setProperty('--lift', `${lift}px`);
        });
        requestAnimationFrame(animateBeans);
      };
      requestAnimationFrame(animateBeans);
    }
  </script>

  <style is:inline>
    .brew-hero {
