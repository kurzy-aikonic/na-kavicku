---

<BaseLayout title={title} description={description} path="/">
  <section id="uvod" class="brew-hero relative overflow-hidden scroll-mt-28 text-white">
    <div class="absolute inset-0 z-[1] hidden md:block" aria-hidden="true">
      <Image src={bean1} alt="" widths={[64, 96]} sizes="80px" class="bean bean-a bean-interactive" />
      <Image src={bean2} alt="" widths={[64, 96]} sizes="72px" class="bean bean-b bean-interactive" />
      <Image src={bean3} alt="" widths={[64, 96]} sizes="78px" class="bean bean-c bean-interactive" />
      <Image src={bean4} alt="" widths={[64, 96]} sizes="72px" class="bean bean-d bean-interactive" />
      <Image src={bean5} alt="" widths={[64, 96]} sizes="86px" class="bean bean-e bean-interactive" />
    </div>
    <div class="mx-auto max-w-6xl px-4 pb-28 pt-12 md:pb-36 md:pt-16">
      <div class="relative z-10 mt-6 reveal md:mt-10">
        <div class="reveal max-w-3xl">
          <h1 class="text-balance text-5xl font-black uppercase leading-[0.88] tracking-tight md:text-8xl">
            {homepage.heroTitle} <span class="text-[#f3b62d]">{homepage.heroHighlight}</span>
          </h1>
          <p class="mt-5 max-w-xl text-sm text-white/80 md:text-base">
            {homepage.heroSubtitle}
          </p>
          <div class="mt-10 flex flex-wrap gap-4 md:mt-12">
            <a href="#napojovy-listek" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-[#2d1a0f] transition hover:-translate-y-0.5">Nápojový lístek</a>
            <a href="#o-kavarne" class="rounded-full border border-white/40 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10">O kavárně</a>
          </div>
        </div>
      </div>
    </div>

    <div class="paper-edge absolute inset-x-0 bottom-0 z-20 h-22 md:h-28" aria-hidden="true"></div>
  </section>

  <section id="o-kavarne" class="mx-auto max-w-6xl scroll-mt-28 px-4 py-14 reveal md:py-16">
    <div class="mb-10 text-center reveal">
      <p class="text-xs uppercase tracking-[0.2em] text-[#8b6540]">{homepage.aboutEyebrow}</p>
      <h2 class="mt-2 text-4xl font-black uppercase leading-none text-[#2b1d14] md:text-6xl">{homepage.aboutHeading}</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {homepage.aboutCards.map((card) => (
        <div class="rounded-3xl bg-white p-7 shadow-sm ring-1 ring-black/5">
          <h3 class="text-lg font-semibold text-[#121212]">{card.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-black/70">{card.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="napojovy-listek" class="relative scroll-mt-28 overflow-hidden bg-[#2a160c] py-14 text-white reveal">
    <div class="absolute inset-0 z-[1] hidden lg:block" aria-hidden="true">
      <Image src={bean6} alt="" widths={[64, 96, 128]} sizes="90px" class="bean bean-f bean-interactive" />
      <Image src={bean7} alt="" widths={[64, 96, 128]} sizes="92px" class="bean bean-g bean-interactive" />
      <Image src={bean8} alt="" widths={[64, 96, 128]} sizes="100px" class="bean bean-h bean-interactive" />
      <Image src={bean9} alt="" widths={[64, 96, 128]} sizes="88px" class="bean bean-i bean-interactive" />
    </div>
    <div class="paper-edge-top absolute inset-x-0 top-0 h-14" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-4">
      <div class="flex flex-wrap items-end justify-between gap-5">
        <div>
          <h2 class="mt-3 text-3xl font-black uppercase tracking-tight md:text-5xl">Nápojový lístek</h2>
          <p class="mt-3 max-w-xl text-sm text-white/75">Kompletní nabídka z lístku. Filtrovat můžete podle sekcí a vyhledávání.</p>
        </div>
      </div>

      <div class="mt-7 rounded-2xl bg-white/6 p-3 ring-1 ring-white/15">
        <div class="flex flex-wrap gap-2" id="menu-filters">
          <button data-filter="all" class="menu-chip is-active rounded-full bg-white px-4 py-2 text-sm font-semibold text-black">Vše</button>
          {menuSections.map((section) => (
            <button data-filter={section.id} class="menu-chip rounded-full bg-white/10 px-4 py-2 text-sm font-semibold text-white">{section.title}</button>
          ))}
        </div>
        <label class="mt-3 block">
          <span class="sr-only">Vyhledat v menu</span>
          <input id="menu-search" type="text" placeholder="Hledat v menu (např. espresso, tonic, prosecco...)" class="w-full rounded-xl border border-white/20 bg-black/20 px-4 py-3 text-sm text-white placeholder:text-white/45 outline-none ring-0 focus:border-white/40" />
        </label>
        <div class="mt-3 flex items-center justify-between gap-3">
          <p id="menu-page-info" class="text-xs text-white/65">Strana 1 z 1</p>
          <div class="flex items-center gap-2">
            <button id="menu-prev" type="button" class="rounded-lg border border-white/20 px-3 py-1.5 text-xs font-semibold text-white/90 hover:bg-white/10">Předchozí</button>
            <button id="menu-next" type="button" class="rounded-lg border border-white/20 px-3 py-1.5 text-xs font-semibold text-white/90 hover:bg-white/10">Další</button>
          </div>
        </div>
      </div>

      <div class="mt-6 grid gap-3 md:grid-cols-2" id="menu-grid">
        {menuSections.map((section) => (
          <details data-category={section.id} class="menu-section group rounded-2xl bg-white/6 p-4 ring-1 ring-white/15 transition hover:bg-white/10">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
              <div>
                <h3 class="text-base font-semibold">{section.title}</h3>
                <p class="mt-1 text-xs text-white/60">{section.items.length} položek</p>
              </div>
              <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-white/80 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="mt-3 grid gap-2">
              {section.items.map((item) => (
                <div class="menu-item rounded-xl bg-black/15 px-3 py-2" data-search={`${section.title} ${item.name} ${item.desc ?? ''}`}>
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-sm font-semibold text-white">{item.name}</p>
                      {item.desc && <p class="mt-0.5 text-xs text-white/60">{item.desc}</p>}
                    </div>
                    <p class="shrink-0 rounded-lg bg-white/10 px-2 py-1 text-xs font-semibold text-[#f3b62d]">{item.price}</p>
                  </div>
                </div>
              ))}
