    .bean-a { top: 14%; right: 10%; width: 68px; --rot: -18deg; }
    .bean-b { top: 28%; right: 22%; width: 62px; --rot: 12deg; }
    .bean-c { top: 54%; right: 8%; width: 70px; --rot: -32deg; }
    .bean-d { top: 72%; left: 7%; width: 62px; --rot: 20deg; opacity: 0.75; }
    .bean-e { top: 10%; left: 8%; width: 78px; --rot: -14deg; opacity: 0.82; }
    .bean-f { top: 20%; right: 7%; width: 78px; --rot: 10deg; }
    .bean-g { top: 66%; right: 9%; width: 86px; --rot: -16deg; opacity: 0.82; }
    .bean-h { bottom: 11%; left: 6%; width: 95px; --rot: 8deg; opacity: 0.8; }
    .bean-i { top: 36%; left: 8%; width: 74px; --rot: -22deg; }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
