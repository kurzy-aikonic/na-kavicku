---
import {Image} from 'astro:assets'
import {site} from '../config/site'
import footerBeansBg from '../assets/images/footer-beans-transparent.png'
import logoNaKavicku from '../assets/images/logo-na-kavicku.png'
---

<footer class="footer-root relative overflow-visible bg-[#2a160c] text-white">
  <div class="pointer-events-none absolute inset-x-0 top-0 z-30 -translate-y-[98%]" aria-hidden="true">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="h-16 w-full fill-[#2a160c] md:h-20">
      <path d="M0,28 C95,58 180,6 280,36 C365,62 455,8 545,34 C630,60 726,16 810,41 C905,69 1000,11 1085,38 C1175,66 1275,16 1360,40 C1400,52 1425,56 1440,54 L1440,120 L0,120 Z"></path>
    </svg>
  </div>

  <div class="pointer-events-none absolute inset-x-0 bottom-0 z-0 flex justify-center" aria-hidden="true">
    <Image
      src={footerBeansBg}
      alt=""
      widths={[640, 960, 1280]}
      sizes="(min-width: 1024px) 720px, 70vw"
      loading="lazy"
      class="footer-beans-image w-[66vw] min-w-[320px] max-w-[900px] object-contain"
    />
  </div>
  <div class="relative z-10 mx-auto grid max-w-6xl gap-10 px-4 py-14 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-3">
        <Image
          src={logoNaKavicku}
          alt={`Logo ${site.name}`}
          widths={[120, 180, 240]}
          sizes="96px"
          class="footer-brand-logo h-10 w-auto object-contain"
        />
        <div class="text-lg font-semibold">{site.name}</div>
      </div>
      <p class="mt-3 text-sm text-white/70">
        Kavárna, do které se budete rádi vracet.
      </p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        <a class="text-white/80 hover:text-white underline underline-offset-4" href="#napojovy-listek">Nápojový lístek</a>
        <a class="text-white/80 hover:text-white underline underline-offset-4" href="#o-kavarne">O kavárně</a>
        <a class="text-white/80 hover:text-white underline underline-offset-4" href="#kontakt">Kontakt</a>
      </div>
      <div class="mt-5 flex items-center gap-3">
        <a
          href={site.socials.instagram}
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram Na kávičku"
          class="inline-flex size-10 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white/90 transition hover:-translate-y-0.5 hover:bg-white/20 hover:text-white"
        >
          <svg viewBox="0 0 24 24" class="size-5 fill-current" aria-hidden="true">
            <path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 1.8A3.7 3.7 0 0 0 3.8 7.5v9a3.7 3.7 0 0 0 3.7 3.7h9a3.7 3.7 0 0 0 3.7-3.7v-9a3.7 3.7 0 0 0-3.7-3.7h-9Zm9.6 1.4a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4Z" />
          </svg>
        </a>
        <a
          href={site.socials.facebook}
          target="_blank"
          rel="noreferrer"
          aria-label="Facebook Na kávičku"
          class="inline-flex size-10 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white/90 transition hover:-translate-y-0.5 hover:bg-white/20 hover:text-white"
        >
          <svg viewBox="0 0 24 24" class="size-5 fill-current" aria-hidden="true">
            <path d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.5 1.6-1.5H17V4.9A23 23 0 0 0 14.5 4C12 4 10.3 5.5 10.3 8.2V11H8v3h2.3v8h3.2Z" />
          </svg>
        </a>
        <a
          href={site.socials.googleReviews}
          target="_blank"
          rel="noreferrer"
          aria-label="Google recenze Na kávičku"
          class="inline-flex size-10 items-center justify-center rounded-full border border-white/20 bg-[#f3b62d] text-[#2a160c] transition hover:-translate-y-0.5 hover:bg-[#f6c14a]"
        >
          <svg viewBox="0 0 24 24" class="size-5 fill-current" aria-hidden="true">
            <path d="M12 2.5 14.8 8l5.9.9-4.3 4.2 1 5.9-5.4-2.8-5.3 2.8 1-5.9L3.4 8.9 9.3 8 12 2.5Z" />
          </svg>
        </a>
      </div>
    </div>

    <div>
      <div class="text-sm font-semibold tracking-wide text-white/90">Kontakt</div>
      <div class="mt-4 grid gap-2 text-sm text-white/75">
        <a class="hover:text-white" href={`tel:${site.phone.replaceAll(' ', '')}`}>{site.phone}</a>
        <a class="hover:text-white" href={`mailto:${site.email}`}>{site.email}</a>
        <a class="hover:text-white" href={site.socials.maps} target="_blank" rel="noreferrer">{site.address}</a>
        <div>IČO: {site.companyId}</div>
      </div>
    </div>

    <div>
      <div class="text-sm font-semibold tracking-wide text-white/90">Otevírací doba</div>
      <dl class="mt-4 grid gap-3 text-sm text-white/75">
        {site.openingHours.map((row) => (
          <div class="flex items-baseline justify-between gap-4">
            <dt class="text-white/70">{row.days}</dt>
            <dd class="font-semibold text-white">{row.hours}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
  <div class="relative z-10 border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-6 text-xs text-white/60">
      <div class="flex flex-wrap items-center gap-2">
        <span>Copyright © {new Date().getFullYear()} {site.name}</span>
        <span class="text-white/35">•</span>
        <span>
          Vytvořil <a class="hover:text-white underline underline-offset-4" href="https://aikonic.cz" target="_blank" rel="noreferrer">Aikonic.cz</a>
        </span>
      </div>
      <div class="flex gap-3">
        <button class="hover:text-white underline underline-offset-4" type="button" id="open-cookie-settings">cookies</button>
        <a class="hover:text-white underline underline-offset-4" href="/cookies/">zásady cookies</a>
        <a class="hover:text-white underline underline-offset-4" href="/gdpr/">ochrana osobních údajů</a>
        <a class="hover:text-white underline underline-offset-4" href="/robots.txt">robots.txt</a>
        <a class="hover:text-white underline underline-offset-4" href="/sitemap.xml">sitemap</a>
      </div>
    </div>
  </div>
</footer>

<style is:inline>
  .footer-root {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-beans-image {
    opacity: 0.92;
    mix-blend-mode: normal;
    filter: brightness(1.02) contrast(1.08) saturate(1.02) drop-shadow(0 8px 14px rgba(0, 0, 0, 0.3));
  }

  .footer-brand-logo {
    filter: brightness(0) invert(1);
  }
</style>

<script is:inline>
  const cookieSettingsBtn = document.getElementById('open-cookie-settings');
  if (cookieSettingsBtn) {
    cookieSettingsBtn.addEventListener('click', () => {
      if (typeof window.openCookieSettings === 'function') {
        window.openCookieSettings();
      }
    });
  }
</script>

