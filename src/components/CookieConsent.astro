---
import {site} from '../config/site'
---

<section
  id="cookie-consent"
  class="cookie-consent fixed inset-x-0 bottom-0 z-[70] hidden p-3 md:p-4"
  aria-label="Nastavení cookies"
>
  <div class="mx-auto max-w-5xl rounded-2xl border border-black/10 bg-[#fbf7ea] p-4 shadow-2xl md:p-5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="max-w-3xl">
        <h2 class="text-base font-semibold text-[#2a160c] md:text-lg">Cookies a soukromí</h2>
        <p class="mt-2 text-sm leading-relaxed text-black/75">
          Používáme pouze nezbytné cookies pro správné fungování webu. Volitelné analytické a marketingové
          cookies zapneme pouze s vaším souhlasem podle pravidel EU a ČR.
          <a href="/cookies/" class="underline underline-offset-4 text-[#8b6540] hover:text-[#6f4f33]">Zobrazit zásady cookies</a>.
        </p>
      </div>
      <div class="flex shrink-0 flex-wrap gap-2">
        <button
          type="button"
          data-cookie-action="reject"
          class="rounded-full border border-black/15 bg-white px-4 py-2 text-sm font-semibold text-[#2a160c] hover:bg-[#f3ebdc]"
        >
          Pouze nezbytné
        </button>
        <button
          type="button"
          data-cookie-action="accept-all"
          class="rounded-full bg-[#2a160c] px-4 py-2 text-sm font-semibold text-white hover:bg-[#3a2113]"
        >
          Přijmout vše
        </button>
      </div>
    </div>

    <details class="mt-4 rounded-xl border border-black/10 bg-white/70 p-3">
      <summary class="cursor-pointer list-none text-sm font-semibold text-[#2a160c]">Podrobné nastavení</summary>
      <div class="mt-3 grid gap-3 text-sm">
        <label class="flex items-start justify-between gap-3 rounded-lg bg-white p-3 ring-1 ring-black/5">
          <span>
            <span class="block font-semibold text-[#2a160c]">Nezbytné cookies</span>
            <span class="mt-1 block text-black/70">Zajišťují bezpečnost, navigaci a základní funkce webu.</span>
          </span>
          <input type="checkbox" checked disabled class="mt-1 size-4 accent-[#2a160c]" />
        </label>
        <label class="flex items-start justify-between gap-3 rounded-lg bg-white p-3 ring-1 ring-black/5">
          <span>
            <span class="block font-semibold text-[#2a160c]">Analytické cookies</span>
            <span class="mt-1 block text-black/70">Pomáhají anonymně měřit návštěvnost a zlepšovat web.</span>
          </span>
          <input id="cookie-analytics" type="checkbox" class="mt-1 size-4 accent-[#2a160c]" />
        </label>
        <label class="flex items-start justify-between gap-3 rounded-lg bg-white p-3 ring-1 ring-black/5">
          <span>
            <span class="block font-semibold text-[#2a160c]">Marketingové cookies</span>
            <span class="mt-1 block text-black/70">Používají se pro personalizaci reklamy a měření kampaní.</span>
          </span>
          <input id="cookie-marketing" type="checkbox" class="mt-1 size-4 accent-[#2a160c]" />
        </label>
      </div>
      <div class="mt-3 flex flex-wrap gap-2">
        <button
          type="button"
          data-cookie-action="save-preferences"
          class="rounded-full bg-[#c58a2a] px-4 py-2 text-sm font-semibold text-white hover:bg-[#b77d1f]"
        >
          Uložit volby
        </button>
      </div>
    </details>

    <p class="mt-3 text-xs text-black/60">
      Správce: {site.name}, IČO: {site.companyId}, {site.address}, kontakt: {site.email}
    </p>
  </div>
</section>

<script is:inline>
  const CONSENT_VERSION = 1;
  const STORAGE_KEY = 'nk_cookie_consent';
  const COOKIE_NAME = 'nk_cookie_consent';
  const COOKIE_MAX_AGE = 60 * 60 * 24 * 180; // 180 days

  const root = document.getElementById('cookie-consent');
  if (root) {
    const analyticsInput = document.getElementById('cookie-analytics');
    const marketingInput = document.getElementById('cookie-marketing');
    const actionButtons = root.querySelectorAll('[data-cookie-action]');

    const writeCookie = (value) => {
      document.cookie = `${COOKIE_NAME}=${encodeURIComponent(value)}; Max-Age=${COOKIE_MAX_AGE}; Path=/; SameSite=Lax`;
    };

    const readStoredConsent = () => {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    };

    const publishConsent = (consent) => {
      window.NK_COOKIE_CONSENT = consent;
      window.dispatchEvent(new CustomEvent('nk:cookie-consent-changed', {detail: consent}));
    };

    const persistConsent = (consent) => {
      const payload = {
        ...consent,
        version: CONSENT_VERSION,
        updatedAt: new Date().toISOString(),
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
      writeCookie(JSON.stringify(payload));
      publishConsent(payload);
      root.classList.add('hidden');
    };

    const applyStoredConsent = () => {
      const consent = readStoredConsent();
      if (!consent || consent.version !== CONSENT_VERSION) {
        root.classList.remove('hidden');
        return;
      }

      if (analyticsInput) analyticsInput.checked = Boolean(consent.analytics);
      if (marketingInput) marketingInput.checked = Boolean(consent.marketing);
      publishConsent(consent);
      root.classList.add('hidden');
    };

    actionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const action = button.getAttribute('data-cookie-action');
        if (action === 'accept-all') {
          persistConsent({necessary: true, analytics: true, marketing: true});
          return;
        }

        if (action === 'reject') {
          persistConsent({necessary: true, analytics: false, marketing: false});
          return;
        }

        if (action === 'save-preferences') {
          persistConsent({
            necessary: true,
            analytics: Boolean(analyticsInput?.checked),
            marketing: Boolean(marketingInput?.checked),
          });
        }
      });
    });

    window.openCookieSettings = () => {
      root.classList.remove('hidden');
      root.scrollIntoView({behavior: 'smooth', block: 'end'});
    };

    applyStoredConsent();
  }
</script>
